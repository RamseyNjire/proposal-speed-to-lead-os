      "parameters": {
        "jsCode": "const brief = $json.discovery_brief || {};\nconst dossier = $json.research_dossier || {};\nconst client = $json.client_name || 'Client';\nconst problem = brief.problem_summary || 'Key growth bottlenecks identified during discovery.';\nconst goals = brief.goal_summary || 'Define and execute a profitable growth system.';\nconst metrics = brief.key_metrics || {};\n\nconst sectionTitles = [\n  'Executive Summary',\n  'Scope of Services',\n  'Strategy and Approach',\n  'Budget and Pricing',\n  'Terms and Conditions'\n];\n\nconst currentRevenue = metrics.monthly_revenue_current ? `$${metrics.monthly_revenue_current.toLocaleString()}` : 'current baseline';\nconst targetRevenue = metrics.monthly_revenue_90d_target ? `$${metrics.monthly_revenue_90d_target.toLocaleString()}` : 'target baseline';\nconst topCompetitor = (brief.competitors || [])[0] || 'category leaders';\n\nconst baseContent = {\n  'Executive Summary': `${client} has strong brand demand and community trust. Current challenge: ${problem}`,\n  'Scope of Services': 'Paid social strategy, creative iteration framework, CRO coordination, retention alignment (email/SMS), and weekly reporting cadence.',\n  'Strategy and Approach': `90-day execution focused on profitable scaling, trust-first creative testing, and retention leverage. Target outcome: ${goals}`,\n  'Budget and Pricing': `Initial paid media test budget starts at approximately $20,000 with phased service scope tied to CAC/ROAS performance gates from ${currentRevenue} toward ${targetRevenue}.`,\n  'Terms and Conditions': `Approval flow includes human QA and founder sign-off before send. Competitive context includes ${topCompetitor}; final deliverables follow agreed communication cadence and success metrics.`\n};\n\nconst sections = sectionTitles.map((title) => ({ title, content: baseContent[title] || '' }));\nconst body = [\n  `Marketing Proposal for ${client}`,\n  '',\n  ...sections.flatMap((s) => [`## ${s.title}`, s.content, ''])\n].join('\\n');\n\nreturn [{\n  json: {\n    ...$json,\n    status: 'DRAFT_READY',\n    qa_status: 'PENDING',\n    founder_status: 'PENDING',\n    reviewer: '',\n    review_notes: '',\n    reviewed_at_utc: '',\n    draft_ready_at_utc: new Date().toISOString(),\n    proposal_section_draft: {\n      case_id: $json.case_id,\n      sections,\n      draft_body_markdown: body\n    },\n    gmail_draft_payload: {\n      case_id: $json.case_id,\n      subject: `Marketing Proposal for ${client}`,\n      body,\n      gmail_draft_id: `draft-${$json.case_id}`\n    }\n  }\n}];"
      },
      "id": "99fc2d45-03c6-48ad-86f0-bf79d7692208",
      "name": "Build Proposal Sections",
