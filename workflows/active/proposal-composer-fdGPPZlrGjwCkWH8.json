      "parameters": {
        "sendTo": "ramsey@intellom8.com",
        "subject": "={{ \"QA Review Needed: \" + ($json.gmail_draft_payload.subject || \"Proposal\") + \" [\" + ($json.case_id || \"no-case-id\") + \"]\" }}",
        "emailType": "html",
        "message": "={{ `\n<div style=\"font-family:Arial,sans-serif;line-height:1.5;color:#111\">\n  <h2 style=\"margin:0 0 12px\">QA Review Required</h2>\n  <p style=\"margin:0 0 8px\"><strong>Case ID:</strong> ${$json.case_id || \"missing-case-id\"}</p>\n  <p style=\"margin:0 0 16px\"><strong>Client:</strong> ${$json.client_name || \"Client\"}</p>\n  <div style=\"margin:16px 0\">\n    <a href=\"https://webhooks.intellom8.com/webhook/qa-approval-action?action=approve&case_id=${encodeURIComponent($json.case_id || \"\")}\"\n       style=\"display:inline-block;background:#0b8043;color:#fff;text-decoration:none;padding:10px 16px;border-radius:6px;margin-right:8px\">Approve</a>\n    <a href=\"mailto:ramsey@intellom8.com?subject=${encodeURIComponent(\"Revision Request - \" + ($json.case_id || \"no-case-id\"))}&body=${encodeURIComponent(\"Case ID: \" + ($json.case_id || \"\") + \"\\n\\nRequested changes:\\n-\")}\"\n       style=\"display:inline-block;background:#b3261e;color:#fff;text-decoration:none;padding:10px 16px;border-radius:6px\">Request Changes (add notes)</a>\n  </div>\n  <hr style=\"margin:16px 0;border:none;border-top:1px solid #ddd\" />\n  <h3 style=\"margin:0 0 8px\">Draft Preview</h3>\n  <pre style=\"white-space:pre-wrap;background:#f7f7f7;padding:12px;border-radius:6px\">${$json.gmail_draft_payload?.body || \"No draft body\"}</pre>\n</div>\n` }}",
        "options": {}
      },
