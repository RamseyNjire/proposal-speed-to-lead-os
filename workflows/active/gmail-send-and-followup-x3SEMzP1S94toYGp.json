      ]
    },
    {
      "parameters": {
        "sendTo": "={{ $json.client_email }}",
        "subject": "={{ $json.gmail_draft_payload.subject || (\"Proposal for \" + ($json.client_name || \"Client\")) }}",
        "emailType": "text",
        "message": "={{ $json.gmail_draft_payload.body || $json.proposal_section_draft.draft_body_markdown }}",
        "options": {}
      },
      "id": "1652137a-4a63-4c67-a8a3-ad53d00f54ec",
