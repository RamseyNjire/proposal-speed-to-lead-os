    {
      "parameters": {
        "jsCode": "const founder = String($json.founder_status || '').toUpperCase();\nif (founder !== 'APPROVED') {\n  throw new Error('Refusing send: founder_status is not APPROVED');\n}\n\nreturn [{\n  json: {\n    ...$json,\n    status: 'APPROVED'\n  }\n}];"
      },
