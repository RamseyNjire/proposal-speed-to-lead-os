      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "pwMK2jDEWY5arMX3",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const sentAt = new Date(Date.now());\nconst followup = new Date(sentAt.getTime() + 48 * 3600 * 1000).toISOString();\nreturn [{\n  json: {\n    ...$json,\n    sent_at_utc: sentAt.toISOString(),\n    approved_at_utc: $json.approved_at_utc || sentAt.toISOString(),\n    followup_due_at_utc: followup,\n    status: 'SENT',\n    final_status: 'FOLLOWUP_DUE'\n  }\n}];"
      },
